{
  "govnl": {
    "quote": {
      "text": {
        "font-style": {
          "$type": "text",
          "$value": "italic"
        }
      },
      "author": {
        "font-weight": {
          "$type": "fontWeights",
          "$value": "{govnl.typography.font-weight.regular}"
        }
      },
      "padding-inline-start": {
        "$type": "dimension",
        "$value": "{govnl.dimension.size.300}"
      },
      "border-inline-start": {
        "$type": "border",
        "$value": "{govnl.border.border-width.lg} solid {govnl.brand.primary-1.500}"
      }
    }
  }
}