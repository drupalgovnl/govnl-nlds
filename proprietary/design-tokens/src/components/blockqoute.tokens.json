{
  "govnl": {
    "quote": {
      "text": {
        "font-style": {
          "$type": "text",
          "$value": "italic"
        }
      },
      "border-inline-start": {
        "style": {
          "$type": "border",
          "$value": {
            "style": "solid"
          }
        },
        "color": {
          "$type": "border",
          "$value": {
            "color": "{govnl.color.hemelblauw.500}"
          }
        },
        "width": {
          "$type": "border",
          "$value": {
            "width": "{govnl.border.border-width.lg}"
          }
        }
      },
      "author": {
        "font-weight": {
          "$type": "fontWeights",
          "$value": "{govnl.typography.font-weight.regular}"
        }
      },
      "padding-inline-start": {
        "$type": "dimension",
        "$value": "{govnl.dimension.size.300}"
      }
    }
  }
}