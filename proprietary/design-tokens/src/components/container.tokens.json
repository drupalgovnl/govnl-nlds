{
  "govnl": {
    "container": {
      "max-inline-size": {
        "$type": "dimension",
        "$value": "calc(8 * {govnl.dimension.size.2000})"
      },
      "padding-inline": {
        "$type": "dimension",
        "$value": "{govnl.dimension.size.200}"
      },
      "gap": {
        "small": {
          "column-gap": {
            "$type": "dimension",
            "$value": "0"
          },
          "row-gap": {
            "$type": "dimension",
            "$value": "{govnl.space.sm}"
          }
        },
        "medium": {
          "column-gap": {
            "$type": "dimension",
            "$value": "0"
          },
          "row-gap": {
            "$type": "dimension",
            "$value": "{govnl.space.md}"
          }
        },
        "large": {
          "column-gap": {
            "$type": "dimension",
            "$value": "0"
          },
          "row-gap": {
            "$type": "dimension",
            "$value": "{govnl.space.lg}"
          }
        }
      }
    }
  }
}
